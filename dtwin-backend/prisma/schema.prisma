generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["authentication", "user_management", "analytics", "telemetry"]
}

enum Role {
  admin
  user
  @@schema("authentication")
}

enum OtpType {
  registration
  forgot_password
  change_email
  change_password
  account_deletion
  @@schema("authentication")
}

enum gender {
  male
  female
  @@schema("user_management")
}

model User {
  id                 String           @id @default(uuid()) @db.Uuid
  username           String           @unique @db.VarChar(100)
  email              String           @unique @db.VarChar(100)
  password           String?          @db.VarChar(100)
  role               Role             @default(user)
  provider           String           @default("local") @db.VarChar(20)
  provider_id        String?          @db.VarChar(100)
  is_verified        Boolean          @default(false)
  is_active          Boolean          @default(true)
  deletion_requested Boolean          @default(false)
  created_at         DateTime         @default(now()) @db.Timestamp(0)
  updated_at         DateTime         @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at         DateTime?        @db.Timestamp(0)

  profile            ProfileUser?
  otp_logs           OtpLog[]
  refresh_tokens     RefreshToken[]
  password_resets    PasswordReset[]
  login_logs         LoginLog[]
  analytics_logs     FaceAnalyticsLog[]
  user_goals         UserGoal[]
  daily_logs         DailyLog[]

  @@map("users")
  @@schema("authentication")
}

model OtpLog {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  otp_code      String    @db.VarChar(10)
  type          OtpType
  target        String    @db.VarChar(100)
  expired_at    DateTime  @db.Timestamp(0)
  is_used       Boolean   @default(false)
  attempt_count Int       @default(0)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("otp_logs")
  @@schema("authentication")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  token        String    @unique @db.Text
  ip_address   String?   @db.VarChar(45)
  user_agent   String?   @db.Text
  is_revoked   Boolean   @default(false)
  expired_at   DateTime  @db.Timestamp(0)
  last_used_at DateTime  @default(now()) @db.Timestamp(0)
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@schema("authentication")
}

model PasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique @db.Text
  is_used    Boolean   @default(false)
  expired_at DateTime  @db.Timestamp(0)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_resets")
  @@schema("authentication")
}

model LoginLog {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String?   @db.Uuid 
  identifier     String    @db.VarChar(100)
  ip_address     String?   @db.VarChar(45)
  user_agent     String?   @db.Text
  status         String    @db.VarChar(20)
  failure_reason String?   @db.VarChar(255)
  location       String?   @db.VarChar(100)
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  user           User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("login_logs")
  @@schema("authentication")
}

model ProfileUser {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @unique @db.Uuid 
  full_name     String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  birth_date    DateTime? @db.Date
  gender        gender?
  profile_image String?   @db.Text
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at    DateTime? @db.Timestamp(0)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profile_users")
  @@schema("user_management")
}

model FaceAnalyticsLog {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String?  @db.Uuid 
  predicted_age    Int?
  confidence_score Decimal? @db.Decimal(5, 4)
  emotion          String?  @db.VarChar(50)
  gender           String   @db.VarChar(20)
  is_known_face    Boolean  @default(false)
  source           String?  @db.VarChar(100)
  captured_at      DateTime @default(now()) @db.Timestamp(0)
  user             User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("face_analytics_logs")
  @@schema("analytics")
}

model UserGoal {
  id                 String    @id @default(uuid()) @db.Uuid
  user_id            String    @unique @db.Uuid
  focus_sleep        Boolean   @default(false)
  focus_productivity Boolean   @default(false)
  focus_fitness      Boolean   @default(false)
  focus_screen_time  Boolean   @default(false)
  created_at         DateTime  @default(now()) @db.Timestamp
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  deleted_at         DateTime? @db.Timestamp(0)
  user               User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_goals")
  @@schema("user_management")
}

model DailyLog {
  log_id                     String    @id @default(uuid()) @db.Uuid
  user_id                    String    @db.Uuid
  log_date                   DateTime  @db.Date
  is_weekend                 Boolean   @default(false)
  sleep_duration             Decimal?  @db.Decimal(5, 2)
  sleep_quality              Int?
  study_work_duration        Decimal?  @db.Decimal(5, 2)
  break_duration             Decimal?  @db.Decimal(5, 2)
  physical_activity_duration Decimal?  @db.Decimal(5, 2)
  screen_time_duration       Decimal?  @db.Decimal(5, 2)
  stress_level               Int?
  mood_score                 Int?
  focus_score                Int?
  task_completed             Int?
  task_planned               Int?
  completion_ratio           Decimal?  @db.Decimal(5, 2)
  fatigue_accumulation       Decimal?  @db.Decimal(5, 2)
  productivity_score         Decimal?  @db.Decimal(5, 2)
  created_at                 DateTime  @default(now()) @db.Timestamp
  deleted_at                 DateTime? @db.Timestamp
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, log_date])
  @@map("daily_logs")
  @@schema("telemetry")
}